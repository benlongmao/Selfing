# ============================================
# Environment template (s-main / open-source)
# ============================================
# Usage:
# 1. Copy to .env:  cp .env.example .env
# 2. Fill secrets and paths in .env (ignored by git — never commit)
# 3. Feature flags and thresholds: prefer config/settings.yaml
# 4. Full env → YAML mapping: backend/config.py → ENV_MAPPING
# Precedence: .env > settings.yaml > code defaults
# ============================================

# ============================================
# I — Secrets (API keys, passwords)
# ============================================

# DeepSeek (config: models.deepseek.api_key)
# Sign up: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Anthropic Claude (config: models.claude.api_key)
# Sign up: https://console.anthropic.com/
# Switch: settings.yaml → system.model_provider: claude_api
CLAUDE_API_KEY=

# OpenAI or compatible (config: models.openai.* when MODEL_PROVIDER=openai_api)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# vLLM / OpenAI-compatible gateway (config: models.vllm.* when MODEL_PROVIDER=vllm)
# Local vLLM may use empty/placeholder key; hosted gateways follow provider docs
VLLM_API_KEY=
VLLM_BASE_URL=
MODEL_ID=
# Legacy alias for MODEL_ID (either works)
# VLLM_MODEL=

# Optional overrides for default base_url / model_id from settings.yaml
# DEEPSEEK_BASE_URL=
# DEEPSEEK_MODEL=
# CLAUDE_BASE_URL=
# CLAUDE_MODEL=
# CLAUDE_LITE_MODEL=

# Tavily search (optional — omit to disable search tool)
# https://tavily.com/
TAVILY_API_KEY=

# Moltbook (optional)
MOLTBOOK_API_KEY=

# Email (optional; backend/tools/email_tool.py reads these directly)
EMAIL_USER=
EMAIL_PASSWORD=
# Override SMTP/IMAP hosts when not using NetEase defaults
# SMTP_SERVER=
# SMTP_PORT=
# IMAP_SERVER=
# IMAP “Sent” folder name (auto-detect if unset)
# IMAP_SENT_FOLDER=

# ============================================
# II — Model routing (same semantics as settings.yaml)
# ============================================

# Typical values: deepseek_api | claude_api | openai_api | vllm | kimi_api
# See system.model_provider in settings.yaml
# Default is DeepSeek; fill DEEPSEEK_API_KEY before the first chat, or switch
# MODEL_PROVIDER and fill the corresponding provider key above.
MODEL_PROVIDER=deepseek_api

# ============================================
# III — Paths and caches
# ============================================

DB_PATH=data.db

HF_HOME=
TRANSFORMERS_CACHE=
MODELSCOPE_CACHE=./models

# ============================================
# IV — Runtime (HF / CUDA)
# ============================================

HF_ENDPOINT=https://hf-mirror.com
HF_HUB_ENABLE_HF_TRANSFER=1
CUDA_VISIBLE_DEVICES=

# ============================================
# V — Optional integrations
# ============================================

TUSHARE_TOKEN=

# ============================================
# VI — Advanced overrides
# ============================================
# Examples: CHAT_MAX_TOOL_TURNS, HEARTBEAT_ENABLED, SELF_TICK_INTERVAL,
# AGENT_NAME, DRIFT_* — keys live in backend/config.py → ENV_MAPPING
# (not every key is duplicated in this template.)
